<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coupons_cell_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/sdk_pay_spacer_xs"
            android:layout_marginStart="@dimen/sdk_pay_spacer_l"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/Body.Body10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sdk_pay_coupons_title"
                android:textColor="?attr/sdk_pay_text_primary" />

            <TextView
                android:id="@+id/coupon_selection_title"
                style="@style/Body.Body30"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sdk_pay_spacer_xxxs"
                android:textColor="?attr/sdk_pay_text_secondary"
                tools:text="@string/sdk_pay_coupon_not_selected_title" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/coupon_content_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/sdk_pay_spacer_l"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/coupons_count"
                style="@style/Subheadline10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="@dimen/sdk_pay_spacer_s"
                android:background="@drawable/sdk_pay_bg_coupon_count"
                android:drawableRight="@drawable/sdk_pay_ic_coupon"
                android:drawablePadding="@dimen/sdk_pay_spacer_xxxs"
                android:gravity="center"
                android:maxLines="1"
                android:textAlignment="center"
                android:textColor="?attr/sdk_pay_text_primary"
                app:drawableEndCompat="@drawable/sdk_pay_ic_coupon"
                tools:ignore="UseCompatTextViewDrawableXml"
                tools:text="3" />

            <LinearLayout
                android:id="@+id/selected_coupon_nominal_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="@dimen/sdk_pay_spacer_s"
                android:background="@drawable/sdk_pay_bg_selected_coupon"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/selected_coupon_nominal"
                    style="@style/Subheadline20"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/sdk_pay_ic_coupon"
                    android:drawablePadding="@dimen/sdk_pay_spacer_xxs"
                    android:gravity="center"
                    android:textColor="?attr/sdk_pay_text_primary"
                    app:drawableStartCompat="@drawable/sdk_pay_ic_coupon"
                    tools:ignore="UseCompatTextViewDrawableXml"
                    tools:text="–200,00 ₽" />

                <ImageView
                    android:id="@+id/unselect_coupon_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sdk_pay_spacer_s"
                    android:src="@drawable/sdk_pay_ic_close"
                    android:tint="?attr/sdk_pay_icon_primary"
                    app:tint="?attr/sdk_pay_icon_primary"
                    tools:ignore="UseAppTint" />

            </LinearLayout>

            <ImageView
                android:id="@+id/open_coupon_list_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/sdk_pay_ic_arrow_down" />

        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sdk_pay_coupon_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sdk_pay_spacer_xxs"
        android:orientation="horizontal"
        android:overScrollMode="never"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/sdk_pay_coupon_item" />

    <TextView
        android:id="@+id/sdk_pay_coupon_selection_hint"
        style="@style/Body.Body30"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/sdk_pay_spacer_l"
        android:layout_marginBottom="@dimen/sdk_pay_spacer_xs"
        android:text="@string/sdk_pay_coupon_selection_hint"
        android:textColor="?attr/sdk_pay_text_secondary" />

</LinearLayout>