<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/sdk_pay_component_horizontal_padding"
    android:background="?attr/sdk_pay_surface_primary"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="@dimen/sdk_pay_bottom_sheet_dialog_content_min_height"
    android:paddingBottom="@dimen/sdk_pay_spacer_xs">

    <include
        android:id="@+id/pay_title"
        layout="@layout/sdk_pay_pay_title_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="@dimen/sdk_pay_spacer_xs" />

    <include
        android:id="@+id/product_details"
        layout="@layout/sdk_pay_product_details_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/pay_title"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/button_container"
        android:layout_below="@id/product_details"
        android:fadeScrollbars="false"
        android:scrollbarThumbVertical="?attr/sdk_pay_icon_quaternary"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/sdk_pay_spacer_m"
            android:layout_marginBottom="@dimen/sdk_pay_spacer_s"
            android:orientation="vertical"
            tools:ignore="UseCompoundDrawables">

            <ImageView
                android:id="@+id/result_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:importantForAccessibility="no"
                tools:src="@drawable/sdk_pay_illustration_fail_result" />

            <TextView
                android:id="@+id/result_message"
                style="@style/Body.Body10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:textColor="?attr/sdk_pay_text_primary" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <Button
            android:id="@+id/payment_methods_button"
            style="@style/Theme.ActionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/sdk_pay_spacer_s"
            android:backgroundTint="?attr/sdk_pay_surface_accent"
            android:text="@string/sdk_pay_payment_result_payment_methods_button"
            android:textColor="?attr/sdk_pay_text_quaternary_constant" />

        <Button
            android:id="@+id/send_receipt_button"
            style="@style/Theme.ActionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/sdk_pay_spacer_s"
            android:backgroundTint="?attr/sdk_pay_surface_secondary"
            android:text="@string/sdk_pay_send_receipt_by_mail_text"
            android:textColor="?attr/sdk_pay_text_accent"
            android:visibility="gone" />

    </LinearLayout>

</RelativeLayout>