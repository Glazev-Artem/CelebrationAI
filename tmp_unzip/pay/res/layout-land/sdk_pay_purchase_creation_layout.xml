<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/sdk_pay_surface_primary"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            layout="@layout/sdk_pay_pay_title_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/sdk_pay_component_horizontal_padding" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="?attr/sdk_pay_bg_primary"
            android:fadeScrollbars="false"
            android:scrollbarThumbVertical="?attr/sdk_pay_icon_quaternary"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/sdk_pay_bg_bottom_island_item"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/sdk_pay_spacer_xs">

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sdk_pay_spacer_xs" />

                    <include layout="@layout/sdk_pay_expandable_product_details_layout" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sdk_pay_spacer_xxs" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/sdk_pay_root_discount_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sdk_pay_spacer_xs"
                    android:background="@drawable/sdk_pay_bg_island_item"
                    android:orientation="vertical">

                    <include
                        layout="@layout/sdk_pay_coupons_cell"
                        android:visibility="gone" />

                    <include
                        layout="@layout/sdk_pay_bonuses_cell"
                        android:visibility="gone" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sdk_pay_spacer_xs" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/sdk_pay_bg_top_island_item"
                    android:orientation="vertical">

                    <include
                        layout="@layout/sdk_pay_payment_method_cell"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sdk_pay_spacer_xs" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sdk_pay_spacer_xs" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <FrameLayout
            android:id="@+id/discount_error_anchor"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <include layout="@layout/sdk_pay_purchase_buttons_layout" />

        <TextView
            android:id="@+id/unauthorized_conditions"
            style="@style/Captions.Caption20"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="@dimen/sdk_pay_spacer_l"
            android:layout_marginBottom="@dimen/sdk_pay_spacer_xs"
            android:gravity="center_horizontal"
            android:textColor="?attr/sdk_pay_text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/offer_consent"
            style="@style/Captions.Caption20"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="@dimen/sdk_pay_spacer_l"
            android:layout_marginBottom="@dimen/sdk_pay_spacer_xs"
            android:gravity="center_horizontal"
            android:textColor="?attr/sdk_pay_text_secondary"
            android:visibility="gone" />

        <include
            android:id="@+id/subscription_promo_tariff_purchase_content"
            layout="@layout/sdk_pay_sub_promo_tariff_purchase_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/progress_indicator_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:minHeight="@dimen/sdk_pay_bottom_sheet_dialog_content_min_height"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.88"
            android:background="?attr/sdk_pay_surface_primary" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_indicator"
            android:layout_width="@dimen/sdk_pay_progress_bar_size"
            android:layout_height="@dimen/sdk_pay_progress_bar_size"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="?attr/sdk_pay_icon_accent"
            app:trackCornerRadius="@dimen/sdk_pay_progress_bar_radius" />

    </FrameLayout>

</FrameLayout>
