<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="@dimen/sdk_pay_spacer_m"
    android:clickable="true"
    android:focusable="true">

    <WebView
        android:id="@+id/payment_web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/sdk_pay_spacer_l"
        android:layout_marginBottom="@dimen/sdk_pay_spacer_m"
        android:fadeScrollbars="false"
        android:scrollbarThumbVertical="?attr/sdk_pay_icon_quaternary"
        android:scrollbars="vertical" />

    <FrameLayout
        android:id="@+id/progress_indicator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/sdk_pay_spacer_l"
        android:layout_marginBottom="@dimen/sdk_pay_spacer_m"
        android:background="?attr/sdk_pay_bg_secondary">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="@dimen/sdk_pay_progress_bar_size"
            android:layout_height="@dimen/sdk_pay_progress_bar_size"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="?attr/sdk_pay_icon_accent"
            app:trackCornerRadius="@dimen/sdk_pay_progress_bar_radius" />

    </FrameLayout>

</FrameLayout>