<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/sdk_pay_payment_method_item_width"
    android:layout_height="@dimen/sdk_pay_payment_method_item_height"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/sdk_pay_ripple_foreground"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="@dimen/sdk_pay_spacer_s">

    <ImageView
        android:id="@+id/card_bank_icon"
        android:layout_width="@dimen/sdk_pay_payment_method_bank_icon_size"
        android:layout_height="@dimen/sdk_pay_payment_method_bank_icon_size"
        android:importantForAccessibility="no"
        tools:src="@drawable/sdk_pay_ic_bank_logo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sdk_pay_spacer_s"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/card_number"
            style="@style/Captions.Caption20"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/sdk_pay_text_primary"
            tools:text="••5738" />

        <ImageView
            android:id="@+id/card_payment_system"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:minWidth="@dimen/sdk_pay_payment_method_item_system_logo_min_width"
            android:minHeight="@dimen/sdk_pay_payment_method_item_system_logo_min_height"
            android:importantForAccessibility="no" />

    </LinearLayout>

</LinearLayout>